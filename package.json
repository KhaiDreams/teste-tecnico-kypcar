{
  "name": "teste-tecnico-kypcar",
  "version": "1.0.0",
  "description": "Base backend para teste tecnico Kypcar",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KhaiDreams/teste-tecnico-kypcar.git"
  },
  "keywords": [
    "backend",
    "fastify",
    "typescript",
    "webhook"
  ],
  "author": "Alexandre Crispim",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/KhaiDreams/teste-tecnico-kypcar/issues"
  },
  "homepage": "https://github.com/KhaiDreams/teste-tecnico-kypcar#readme",
  "dependencies": {
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
