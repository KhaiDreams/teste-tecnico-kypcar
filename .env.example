NODE_ENV=development
PORT=3000
LOG_LEVEL=info
PROCESSING_TIMEOUT_MS=60000
WEBHOOK_BASE_URL=http://localhost:3000
AUTO_REGISTER_WEBHOOK=false

#API Credentials
KYPCAR_API_URL=https://dev.api.kypcar.com
KYPCAR_EMAIL=your-email@example.com
KYPCAR_PASSWORD=your-password

#API request settings
KYPCAR_HTTP_TIMEOUT_MS=10000
KYPCAR_RETRY_MAX_ATTEMPTS=3
KYPCAR_RETRY_BASE_DELAY_MS=250